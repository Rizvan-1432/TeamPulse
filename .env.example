# ─── Local development (PostgreSQL on your machine) ───
DATABASE_URL="postgresql://USER@localhost:5432/teampulse?schema=public"

# ─── Neon (recommended for Vercel production) ───
# Get both strings in Neon Console → Connect → Prisma
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Supabase (alternative) ───
# DATABASE_URL="postgresql://postgres.[ref]:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Public app URL (production: https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis (recommended on Vercel for real-time SSE)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: automate Neon setup — scripts/setup-neon.sh
# NEON_API_KEY=""
