generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  CARD_CREATED
  CARD_UPDATED
  CARD_MOVED
  CARD_DELETED
  BOARD_RENAMED
  MEMBER_INVITED
  MEMBER_REMOVED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  avatar    String?
  createdAt DateTime @default(now())

  ownedBoards Board[]       @relation("BoardOwner")
  memberships BoardMember[]
  cards       Card[]
  activities  Activity[]
}

model Board {
  id        String   @id @default(cuid())
  title     String
  ownerId   String
  createdAt DateTime @default(now())

  owner      User          @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    BoardMember[]
  columns    Column[]
  activities Activity[]
}

model BoardMember {
  boardId String
  userId  String
  role    Role @default(EDITOR)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
}

model Column {
  id      String @id @default(cuid())
  boardId String
  title   String
  order   Int

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

model Card {
  id          String    @id @default(cuid())
  columnId    String
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  dueAt       DateTime?
  order       Int
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([columnId])
}

model Activity {
  id        String       @id @default(cuid())
  boardId   String
  userId    String
  type      ActivityType
  message   String
  createdAt DateTime     @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
}
